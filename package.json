    "@astrojs/preact": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7",
    "astro-compress": "^2.4.1",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "slugify": "^1.6.9"
  }
}
