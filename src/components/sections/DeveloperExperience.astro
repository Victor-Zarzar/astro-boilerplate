---
interface Props {
  title: string;
  features: string[];
  terminal: {
    comment: string;
    command: {
      tool: string;
      args: string;
    };
    successSteps: string[];
    readyMessage: string;
  };
}

const { title, features, terminal } = Astro.props;
---

<div
    class="mt-24 p-12 rounded-[40px] bg-linear-to-br from-primary/10 via-background to-background border border-primary/20"
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
            <h2 class="text-3xl font-bold mb-6">{title}</h2>
            <ul class="space-y-4">
                {
                    features.map((item) => (
                        <li class="flex items-center gap-3 text-foreground/70">
                            <div class="w-1.5 h-1.5 rounded-full bg-primary" />
                            {item}
                        </li>
                    ))
                }
            </ul>
        </div>
        <div
            class="bg-black rounded-2xl border border-white/5 p-6 font-mono text-sm overflow-hidden"
        >
            <div class="flex gap-2 mb-4">
                <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
            </div>
            <div class="text-white"># {terminal.comment}</div>
            <div class="flex flex-wrap items-baseline gap-2 mt-1 mb-3">
                <span class="text-white/40">$</span>
                <span class="text-white">{terminal.command.tool}</span>
                <span class="text-white break-all">{terminal.command.args}</span
                >
            </div>
            {
                terminal.successSteps.map((step) => (
                    <div class="text-white">✓ {step}</div>
                ))
            }
            <div class="mt-4 text-white animate-pulse">
                {terminal.readyMessage} _
            </div>
        </div>
    </div>
</div>
