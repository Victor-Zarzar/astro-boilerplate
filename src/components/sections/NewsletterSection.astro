---
import Newsletter from "~/components/islands/Newsletter";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
        <Newsletter client:visible title={title} description={description} />
    </div>
</section>
