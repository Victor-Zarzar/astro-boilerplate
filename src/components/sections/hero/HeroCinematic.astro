---
import { Image } from "astro:assets";
import wormhole from "~/assets/blog/interstellar-wormhole.webp";
import Badge from "~/components/ui/Badge.astro";
import Button from "~/components/ui/Button.astro";
import type { HeroVariantProps } from "./types";

export interface Props extends HeroVariantProps {}

const { badge, title, highlight, description, primaryCta, secondaryCta } =
  Astro.props;
---

<section
    data-hero-variant="cinematic"
    class="min-h-[90vh] flex items-end relative overflow-hidden pt-32 bg-background"
>
    <Image
        src={wormhole}
        alt=""
        aria-hidden="true"
        width={1920}
        height={1080}
        class="absolute inset-0 w-full h-full object-cover"
    />
    <div
        class="absolute inset-0 bg-linear-to-t from-black via-black/70 to-black/20"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10 pb-24">
        <div class="hero-content opacity-0 translate-y-5 max-w-2xl">
            <Badge class="mb-6 border-white/20">
                {badge}
            </Badge>
            <h1
                class="text-4xl md:text-6xl font-bold tracking-tight mb-8 text-white"
            >
                {title}
                <br />
                <span class="text-primary">
                    {highlight}
                </span>
            </h1>
            <p class="text-lg text-white/80 mb-10">
                {description}
            </p>

            <div class="flex flex-col sm:flex-row gap-4 items-start">
                <Button
                    href={primaryCta.href}
                    class="px-8 py-4 rounded-full text-base"
                    aria-label={`${primaryCta.text} - ${title} ${highlight}`}
                >
                    {primaryCta.text}
                </Button>
                <Button
                    href={secondaryCta.href}
                    variant="secondary"
                    class="px-8 py-4 rounded-full text-base backdrop-blur-sm"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${secondaryCta.text} about our features`}
                >
                    {secondaryCta.text}
                </Button>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-content {
        animation: fadeUp 0.8s ease-out forwards;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-content {
            animation: none;
            opacity: 1;
            transform: none;
        }
    }
</style>
