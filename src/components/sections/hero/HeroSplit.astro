---
import { Image } from "astro:assets";
import gargantua from "~/assets/blog/interstellar-gargantua.webp";
import Badge from "~/components/ui/Badge.astro";
import Button from "~/components/ui/Button.astro";
import type { HeroVariantProps } from "./types";

export interface Props extends HeroVariantProps {}

const { badge, title, highlight, description, primaryCta, secondaryCta } =
  Astro.props;
---

<section
    data-hero-variant="split"
    class="min-h-[90vh] flex items-center relative overflow-hidden pt-32 bg-background"
>
    <div class="container mx-auto px-6 relative z-10">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="hero-content opacity-0 translate-y-5 text-left">
                <Badge class="mb-6 border-foreground/10">
                    {badge}
                </Badge>
                <h1
                    class="text-4xl md:text-6xl font-bold tracking-tight mb-8 text-foreground"
                >
                    {title}
                    <br />
                    <span class="text-primary">
                        {highlight}
                    </span>
                </h1>
                <p class="text-lg text-foreground/70 max-w-xl mb-10">
                    {description}
                </p>

                <div class="flex flex-col sm:flex-row gap-4 items-start">
                    <Button
                        href={primaryCta.href}
                        class="px-8 py-4 rounded-full text-base"
                        aria-label={`${primaryCta.text} - ${title} ${highlight}`}
                    >
                        {primaryCta.text}
                    </Button>
                    <Button
                        href={secondaryCta.href}
                        variant="secondary"
                        class="px-8 py-4 rounded-full text-base backdrop-blur-sm"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${secondaryCta.text} about our features`}
                    >
                        {secondaryCta.text}
                    </Button>
                </div>
            </div>

            <div class="relative flex items-center justify-center">
                <div
                    class="orbit-visual relative w-full max-w-md aspect-square rounded-full overflow-hidden shadow-2xl shadow-primary/20"
                >
                    <Image
                        src={gargantua}
                        alt=""
                        aria-hidden="true"
                        width={600}
                        height={600}
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-content {
        animation: fadeUp 0.8s ease-out forwards;
    }

    .orbit-visual {
        animation: spin 60s linear infinite;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-content {
            animation: none;
            opacity: 1;
            transform: none;
        }
        .orbit-visual {
            animation: none;
        }
    }
</style>
