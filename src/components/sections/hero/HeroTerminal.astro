---
import Badge from "~/components/ui/Badge.astro";
import Button from "~/components/ui/Button.astro";
import type { HeroVariantProps } from "./types";

export interface Props extends HeroVariantProps {}

const {
  badge,
  title,
  highlight,
  description,
  primaryCta,
  secondaryCta,
  stats = [],
} = Astro.props;
---

<section
    data-hero-variant="terminal"
    class="min-h-[90vh] flex items-center relative overflow-hidden pt-32 bg-background"
>
    <div class="container mx-auto px-6 relative z-10">
        <div class="hero-content opacity-0 translate-y-5 max-w-2xl font-mono">
            <Badge class="mb-6 border-foreground/10">
                &gt; {badge}
            </Badge>
            <h1
                class="text-4xl md:text-6xl font-bold tracking-tight mb-8 text-foreground"
            >
                {title}
                <br />
                <span class="text-primary">
                    {highlight}
                </span>
            </h1>
            <p class="text-lg text-foreground/70 mb-10">
                {description}
            </p>

            <div class="flex flex-col sm:flex-row gap-4 items-start mb-10">
                <Button
                    href={primaryCta.href}
                    class="px-8 py-4 rounded-full text-base"
                    aria-label={`${primaryCta.text} - ${title} ${highlight}`}
                >
                    {primaryCta.text}
                </Button>
                <Button
                    href={secondaryCta.href}
                    variant="secondary"
                    class="px-8 py-4 rounded-full text-base backdrop-blur-sm"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${secondaryCta.text} about our features`}
                >
                    {secondaryCta.text}
                </Button>
            </div>

            <div class="grid grid-cols-3 gap-4 max-w-md">
                {
                    stats.map((stat) => (
                        <div class="border border-foreground/10 rounded-lg px-3 py-2 text-center">
                            <div class="text-lg font-bold text-primary">
                                {stat.value}
                            </div>
                            <div class="text-xs text-foreground/50">
                                {stat.label}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .hero-content {
        animation: fadeUp 0.8s ease-out forwards;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-content {
            animation: none;
            opacity: 1;
            transform: none;
        }
    }
</style>
